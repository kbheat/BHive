        "format": "<template>\n  <div style=\"padding:16px;\">\n    <h2>BHive Test</h2>\n    <p>pH: {{ sensors.ph }}</p>\n    <p>EC: {{ sensors.ec }}</p>\n    <p>Temp: {{ sensors.int_temp }}</p>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      sensors: {\n        ph: 'loading...', ec: 'loading...', int_temp: 'loading...'\n      }\n    }\n  },\n  watch: {\n    msg(newVal) {\n      if (newVal && newVal.payload) {\n        this.sensors = newVal.payload\n      }\n    }\n  }\n}\n</script>",

        "format": "<template>\n<div style=\"padding:16px;font-family:sans-serif;\">\n\n  <p style=\"font-size:11px;color:#888;margin:0 0 16px;text-transform:uppercase;letter-spacing:0.08em;\">Crop Settings</p>\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <div style=\"margin-bottom:12px;\">\n      <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Crop Name</p>\n      <input type=\"text\" v-model=\"crop_name\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n    </div>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Start Date</p>\n        <input type=\"date\" v-model=\"start_date\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Days to Harvest</p>\n        <input type=\"number\" v-model=\"days_to_harvest\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n    </div>\n  </div>\n\n  <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Target Ranges</p>\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <div style=\"display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">pH Min</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"ph_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">pH Max</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"ph_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">EC Min</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"ec_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">EC Max</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"ec_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Temp Min °F</p>\n        <input type=\"number\" v-model=\"temp_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Temp Max °F</p>\n        <input type=\"number\" v-model=\"temp_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">RH Min %</p>\n        <input type=\"number\" v-model=\"rh_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">RH Max %</p>\n        <input type=\"number\" v-model=\"rh_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n    </div>\n  </div>\n\n  <button @click=\"saveSettings\" style=\"width:100%;padding:14px;background:#4caf50;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:500;cursor:pointer;\">Save Settings</button>\n\n</div>\n\n<script>\nexport default {\n  data() {\n    return {\n      crop_name: 'Lettuce — Butterhead',\n      start_date: '',\n      days_to_harvest: 42,\n     
    {
        "id": "c9c5def3b477cd4f",
        "type": "ui-template",
        "z": "5b9088f11588525c",
        "group": "",
        "page": "",
        "ui": "06b579fc3bc5fd14",
        "name": "BHive Dashboard",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div style=\"padding:16px;font-family:sans-serif;max-width:1024px;margin:0 auto;\">\n\n    <!-- Crop Tracker -->\n    <div style=\"background:#f5f5f5;border-radius:12px;padding:16px;margin-bottom:12px;\">\n      <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Current Crop\n      </p>\n      <div style=\"display:flex;align-items:center;gap:12px;\">\n        <div\n          style=\"width:40px;height:40px;background:#e8f5e9;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px;\">\n          🌿</div>\n        <div style=\"flex:1;\">\n          <p style=\"font-size:16px;font-weight:500;margin:0;\">{{ msg.crop_name || 'Lettuce — Butterhead' }}</p>\n          <p style=\"font-size:12px;color:#888;margin:2px 0 0;\">Day {{ msg.days_growth || 18 }} of 42 — Vegetative stage\n          </p>\n          <div style=\"height:4px;background:#e0e0e0;border-radius:2px;margin-top:8px;\">\n            <div :style=\"'height:4px;background:#4caf50;border-radius:2px;width:' + (msg.progress || 43) + '%;'\"></div>\n          </div>\n        </div>\n        <div style=\"text-align:right;\">\n          <p style=\"font-size:22px;font-weight:500;color:#4caf50;margin:0;\">{{ msg.progress || 43 }}%</p>\n          <p style=\"font-size:11px;color:#888;margin:2px 0 0;\">to harvest</p>\n        </div>\n      </div>\n    </div>\n\n    <!-- Internal Sensors -->\n    <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Environment —\n      Internal</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;margin-bottom:12px;\">\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">pH</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.ph || '6.1' }}</p>\n        <p style=\"font-size:11px;color:#4caf50;margin:2px 0 0;\">● In range</p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">EC</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.ec || '1.8' }}\n          <span style=\"font-size:12px;color:#888;\">mS</span></p>\n        <p style=\"font-size:11px;color:#4caf50;margin:2px 0 0;\">● In range</p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Int. Temp</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.int_temp || '72' }}\n          <span style=\"font-size:12px;color:#888;\">°F</span></p>\n        <p style=\"font-size:11px;color:#4caf50;margin:2px 0 0;\">● Nominal</p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Int. RH</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.int_rh || '68' }}\n          <span style=\"font-size:12px;color:#888;\">%</span></p>\n        <p style=\"font-size:11px;color:#ef9f27;margin:2px 0 0;\">▲ High</p>\n      </div>\n    </div>\n\n    <!-- External Sensors -->\n    <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Environment —\n      External</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;\">\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Ext. Temp</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.ext_temp || '64' }}\n          <span style=\"font-size:12px;color:#888;\">°F</span></p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Ext. RH</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.ext_rh || '52' }}\n          <span style=\"font-size:12px;color:#888;\">%</span></p>\n      </div>\n    </div>\n\n    <!-- System Status -->\n    <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">System Status\n    </p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;\">\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:#4caf50;\"></div>\n          <span style=\"font-size:13px;flex:1;\">Grow Lights</span>\n          <span style=\"font-size:11px;background:#e8f5e9;color:#2e7d32;padding:2px 8px;border-radius:6px;\">On</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:#4caf50;\"></div>\n          <span style=\"font-size:13px;flex:1;\">Main Pump</span>\n          <span style=\"font-size:11px;background:#e8f5e9;color:#2e7d32;padding:2px 8px;border-radius:6px;\">Running</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:#bdbdbd;\"></div>\n          <span style=\"font-size:13px;flex:1;\">Dosing</span>\n          <span style=\"font-size:11px;background:#f5f5f5;color:#888;padding:2px 8px;border-radius:6px;\">Idle</span>\n        </div>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:#ef9f27;\"></div>\n          <span style=\"font-size:13px;flex:1;\">Humidifier</span>\n          <span style=\"font-size:11px;background:#faeeda;color:#854f0b;padding:2px 8px;border-radius:6px;\">Running</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:#4caf50;\"></div>\n          <span style=\"font-size:13px;flex:1;\">Vents</span>\n          <span style=\"font-size:11px;background:#e8f5e9;color:#2e7d32;padding:2px 8px;border-radius:6px;\">72% open</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Alerts -->\n    <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Alerts</p>\n    <div style=\"background:#faeeda;border:0.5px solid #fac775;border-radius:12px;padding:12px;margin-bottom:8px;\">\n      <p style=\"font-size:13px;font-weight:500;margin:0 0 2px;\">Int. RH High</p>\n      <p style=\"font-size:12px;color:#666;margin:0;\">68% exceeds target (55–65%). Check exhaust fan.</p>\n    </div>\n    <div style=\"background:#fcebeb;border:0.5px solid #f7c1c1;border-radius:12px;padding:12px;\">\n      <p style=\"font-size:13px;font-weight:500;margin:0 0 2px;\">pH Drift</p>\n      <p style=\"font-size:12px;color:#666;margin:0;\">Trending downward over 4h. Last dose: pH Up 12mL.</p>\n    </div>\n\n  </div>\n</template>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "widget:ui",

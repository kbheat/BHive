    {
        "id": "9051afc78bc831d4",
        "type": "ui-template",
        "z": "190cd4b9f45ba92d",
        "group": "d4f328f50745ccd7",
        "page": "",
        "ui": "",
        "name": "BHive Dashboard",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div style=\"padding:16px;font-family:sans-serif;\">\n\n    <div style=\"background:#f5f5f5;border-radius:12px;padding:16px;margin-bottom:12px;\">\n      <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Current Crop\n      </p>\n      <div style=\"display:flex;align-items:center;gap:12px;\">\n        <div\n          style=\"width:40px;height:40px;background:#e8f5e9;border-radius:8px;display:flex;align-items:center;justify-content:center;\">\n          <div style=\"width:20px;height:20px;background:#4caf50;border-radius:50%;\"></div>\n        </div>\n        <div style=\"flex:1;\">\n          <p style=\"font-size:16px;font-weight:500;margin:0;\">{{ msg.payload.crop_name || 'Lettuce — Butterhead' }}</p>\n          <p style=\"font-size:12px;color:#888;margin:2px 0 0;\">Day {{ msg.payload.days_growth || 18 }} of {{\n            msg.payload.days_to_harvest || 42 }}</p>\n          <div style=\"height:4px;background:#e0e0e0;border-radius:2px;margin-top:8px;\">\n            <div\n              :style=\"'height:4px;background:#4caf50;border-radius:2px;width:' + (msg.payload.progress || 43) + '%;'\">\n            </div>\n          </div>\n        </div>\n        <div style=\"text-align:right;\">\n          <p style=\"font-size:22px;font-weight:500;color:#4caf50;margin:0;\">{{ msg.payload.progress || 43 }}%</p>\n          <p style=\"font-size:11px;color:#888;margin:2px 0 0;\">to harvest</p>\n        </div>\n      </div>\n    </div>\n\n    <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Environment —\n      Internal</p>\n    <div style=\"display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px;\">\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">pH</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.payload.ph || '—' }}</p>\n        <p style=\"font-size:11px;margin:2px 0 0;color:#4caf50;\">● In range</p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">EC</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.payload.ec || '—' }}\n          <span style=\"font-size:12px;color:#888;\">mS</span></p>\n        <p style=\"font-size:11px;margin:2px 0 0;color:#4caf50;\">● In range</p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Int. Temp</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.payload.int_temp || '—' }}\n          <span style=\"font-size:12px;color:#888;\">°F</span></p>\n        <p style=\"font-size:11px;margin:2px 0 0;color:#4caf50;\">● Nominal</p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Int. RH</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.payload.int_rh || '—' }}\n          <span style=\"font-size:12px;color:#888;\">%</span></p>\n        <p style=\"font-size:11px;margin:2px 0 0;color:#4caf50;\">● In range</p>\n      </div>\n    </div>\n\n    <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Environment —\n      External</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;\">\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Ext. Temp</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.payload.ext_temp || '—' }}\n          <span style=\"font-size:12px;color:#888;\">°F</span></p>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Ext. RH</p>\n        <p style=\"font-size:22px;font-weight:500;margin:0;\">{{ msg.payload.ext_rh || '—' }}\n          <span style=\"font-size:12px;color:#888;\">%</span></p>\n      </div>\n    </div>\n\n    <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">System Status\n    </p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:10px;\">\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.lights ? '#4caf50' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">Grow Lights</span><span :style=\"'font-size:11px;padding:2px 8px;border-radius:6px;background:' + (msg.payload.lights ? '#e8f5e9' : '#f5f5f5') + ';color:' + (msg.payload.lights ? '#2e7d32' : '#888')\">{{ msg.payload.lights ? 'On' : 'Off' }}</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.main_pump ? '#4caf50' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">Main Pump</span><span :style=\"'font-size:11px;padding:2px 8px;border-radius:6px;background:' + (msg.payload.main_pump ? '#e8f5e9' : '#f5f5f5') + ';color:' + (msg.payload.main_pump ? '#2e7d32' : '#888')\">{{ msg.payload.main_pump ? 'Running' : 'Off' }}</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.pump_a ? '#4caf50' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">Pump A</span><span :style=\"'font-size:11px;padding:2px 8px;border-radius:6px;background:' + (msg.payload.pump_a ? '#e8f5e9' : '#f5f5f5') + ';color:' + (msg.payload.pump_a ? '#2e7d32' : '#888')\">{{ msg.payload.pump_a ? 'Dosing' : 'Idle' }}</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.pump_b ? '#4caf50' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">Pump B</span><span :style=\"'font-size:11px;padding:2px 8px;border-radius:6px;background:' + (msg.payload.pump_b ? '#e8f5e9' : '#f5f5f5') + ';color:' + (msg.payload.pump_b ? '#2e7d32' : '#888')\">{{ msg.payload.pump_b ? 'Dosing' : 'Idle' }}</span>\n        </div>\n      </div>\n      <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:12px;\">\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.ph_up ? '#4caf50' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">pH Up</span><span :style=\"'font-size:11px;padding:2px 8px;border-radius:6px;background:' + (msg.payload.ph_up ? '#e8f5e9' : '#f5f5f5') + ';color:' + (msg.payload.ph_up ? '#2e7d32' : '#888')\">{{ msg.payload.ph_up ? 'Dosing' : 'Idle' }}</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.ph_down ? '#4caf50' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">pH Down</span><span :style=\"'font-size:11px;padding:2px 8px;border-radius:6px;background:' + (msg.payload.ph_down ? '#e8f5e9' : '#f5f5f5') + ';color:' + (msg.payload.ph_down ? '#2e7d32' : '#888')\">{{ msg.payload.ph_down ? 'Dosing' : 'Idle' }}</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.humidifier ? '#ef9f27' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">Humidifier</span><span :style=\"'font-size:11px;padding:2px 8px;border-radius:6px;background:' + (msg.payload.humidifier ? '#faeeda' : '#f5f5f5') + ';color:' + (msg.payload.humidifier ? '#854f0b' : '#888')\">{{ msg.payload.humidifier ? 'Running' : 'Off' }}</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:8px;\">\n          <div\n            :style=\"'width:10px;height:10px;border-radius:50%;background:' + (msg.payload.vents > 0 ? '#4caf50' : '#bdbdbd')\">\n          </div>\n          <span style=\"font-size:13px;flex:1;\">Vents</span><span style=\"font-size:11px;padding:2px 8px;border-radius:6px;background:#e8f5e9;color:#2e7d32;\">{{ msg.payload.vents || 0 }}% open</span>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</template>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 510,
        "y": 380,
        "wires": [

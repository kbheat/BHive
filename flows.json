    {
        "id": "cd94253ac9728d44",
        "type": "ui-template",
        "z": "190cd4b9f45ba92d",
        "group": "36b02f21cc66f12c",
        "page": "",
        "ui": "",
        "name": "Crop Profiles",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n<div style=\"padding:16px;font-family:sans-serif;\">\n\n  <p style=\"font-size:11px;color:#888;margin:0 0 12px;text-transform:uppercase;letter-spacing:0.08em;\">Crop Profiles</p>\n\n  <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;\">\n\n    <div @click=\"active='Lettuce'\" :style=\"'background:' + (active==='Lettuce' ? '#e8f5e9' : '#fff') + ';border:' + (active==='Lettuce' ? '2px solid #4caf50' : '0.5px solid #e0e0e0') + ';border-radius:12px;padding:14px;cursor:pointer;'\">\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n        <div style=\"width:32px;height:32px;border-radius:8px;background:#4caf50;\"></div>\n        <div><p style=\"font-size:14px;font-weight:500;margin:0;\">Lettuce — Butterhead</p><p style=\"font-size:11px;color:#888;margin:0;\">42 days to harvest</p></div>\n        <div v-if=\"active==='Lettuce'\" style=\"margin-left:auto;background:#4caf50;color:#fff;font-size:10px;padding:2px 8px;border-radius:6px;\">Active</div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;\">\n        <p style=\"font-size:11px;color:#888;margin:0;\">pH: 5.5–6.5</p><p style=\"font-size:11px;color:#888;margin:0;\">EC: 0.8–1.6 mS</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">Temp: 60–75°F</p><p style=\"font-size:11px;color:#888;margin:0;\">RH: 50–70%</p>\n      </div>\n    </div>\n\n    <div @click=\"active='Basil'\" :style=\"'background:' + (active==='Basil' ? '#e8f5e9' : '#fff') + ';border:' + (active==='Basil' ? '2px solid #4caf50' : '0.5px solid #e0e0e0') + ';border-radius:12px;padding:14px;cursor:pointer;'\">\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n        <div style=\"width:32px;height:32px;border-radius:8px;background:#8bc34a;\"></div>\n        <div><p style=\"font-size:14px;font-weight:500;margin:0;\">Basil — Genovese</p><p style=\"font-size:11px;color:#888;margin:0;\">28 days to harvest</p></div>\n        <div v-if=\"active==='Basil'\" style=\"margin-left:auto;background:#4caf50;color:#fff;font-size:10px;padding:2px 8px;border-radius:6px;\">Active</div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;\">\n        <p style=\"font-size:11px;color:#888;margin:0;\">pH: 5.5–6.5</p><p style=\"font-size:11px;color:#888;margin:0;\">EC: 1.0–1.6 mS</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">Temp: 65–80°F</p><p style=\"font-size:11px;color:#888;margin:0;\">RH: 50–70%</p>\n      </div>\n    </div>\n\n    <div @click=\"active='Spinach'\" :style=\"'background:' + (active==='Spinach' ? '#e8f5e9' : '#fff') + ';border:' + (active==='Spinach' ? '2px solid #4caf50' : '0.5px solid #e0e0e0') + ';border-radius:12px;padding:14px;cursor:pointer;'\">\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n        <div style=\"width:32px;height:32px;border-radius:8px;background:#2e7d32;\"></div>\n        <div><p style=\"font-size:14px;font-weight:500;margin:0;\">Spinach</p><p style=\"font-size:11px;color:#888;margin:0;\">40 days to harvest</p></div>\n        <div v-if=\"active==='Spinach'\" style=\"margin-left:auto;background:#4caf50;color:#fff;font-size:10px;padding:2px 8px;border-radius:6px;\">Active</div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;\">\n        <p style=\"font-size:11px;color:#888;margin:0;\">pH: 6.0–7.0</p><p style=\"font-size:11px;color:#888;margin:0;\">EC: 1.8–2.3 mS</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">Temp: 55–70°F</p><p style=\"font-size:11px;color:#888;margin:0;\">RH: 50–70%</p>\n      </div>\n    </div>\n\n    <div @click=\"active='Tomato'\" :style=\"'background:' + (active==='Tomato' ? '#e8f5e9' : '#fff') + ';border:' + (active==='Tomato' ? '2px solid #4caf50' : '0.5px solid #e0e0e0') + ';border-radius:12px;padding:14px;cursor:pointer;'\">\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n        <div style=\"width:32px;height:32px;border-radius:8px;background:#e53935;\"></div>\n        <div><p style=\"font-size:14px;font-weight:500;margin:0;\">Cherry Tomato</p><p style=\"font-size:11px;color:#888;margin:0;\">70 days to harvest</p></div>\n        <div v-if=\"active==='Tomato'\" style=\"margin-left:auto;background:#4caf50;color:#fff;font-size:10px;padding:2px 8px;border-radius:6px;\">Active</div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;\">\n        <p style=\"font-size:11px;color:#888;margin:0;\">pH: 5.5–6.5</p><p style=\"font-size:11px;color:#888;margin:0;\">EC: 2.0–3.5 mS</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">Temp: 65–80°F</p><p style=\"font-size:11px;color:#888;margin:0;\">RH: 50–70%</p>\n      </div>\n    </div>\n\n    <div @click=\"active='Strawberry'\" :style=\"'background:' + (active==='Strawberry' ? '#e8f5e9' : '#fff') + ';border:' + (active==='Strawberry' ? '2px solid #4caf50' : '0.5px solid #e0e0e0') + ';border-radius:12px;padding:14px;cursor:pointer;'\">\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n        <div style=\"width:32px;height:32px;border-radius:8px;background:#f06292;\"></div>\n        <div><p style=\"font-size:14px;font-weight:500;margin:0;\">Strawberry</p><p style=\"font-size:11px;color:#888;margin:0;\">90 days to harvest</p></div>\n        <div v-if=\"active==='Strawberry'\" style=\"margin-left:auto;background:#4caf50;color:#fff;font-size:10px;padding:2px 8px;border-radius:6px;\">Active</div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;\">\n        <p style=\"font-size:11px;color:#888;margin:0;\">pH: 5.5–6.5</p><p style=\"font-size:11px;color:#888;margin:0;\">EC: 1.2–1.8 mS</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">Temp: 60–75°F</p><p style=\"font-size:11px;color:#888;margin:0;\">RH: 60–80%</p>\n      </div>\n    </div>\n\n    <div @click=\"active='Kale'\" :style=\"'background:' + (active==='Kale' ? '#e8f5e9' : '#fff') + ';border:' + (active==='Kale' ? '2px solid #4caf50' : '0.5px solid #e0e0e0') + ';border-radius:12px;padding:14px;cursor:pointer;'\">\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n        <div style=\"width:32px;height:32px;border-radius:8px;background:#388e3c;\"></div>\n        <div><p style=\"font-size:14px;font-weight:500;margin:0;\">Kale</p><p style=\"font-size:11px;color:#888;margin:0;\">55 days to harvest</p></div>\n        <div v-if=\"active==='Kale'\" style=\"margin-left:auto;background:#4caf50;color:#fff;font-size:10px;padding:2px 8px;border-radius:6px;\">Active</div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;\">\n        <p style=\"font-size:11px;color:#888;margin:0;\">pH: 5.5–6.5</p><p style=\"font-size:11px;color:#888;margin:0;\">EC: 1.25–1.5 mS</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">Temp: 55–75°F</p><p style=\"font-size:11px;color:#888;margin:0;\">RH: 45–65%</p>\n      </div>\n    </div>\n\n  </div>\n\n  <div v-if=\"active\" style=\"background:#f5f5f5;border-radius:12px;padding:16px;\">\n    <p style=\"font-size:13px;font-weight:500;margin:0 0 12px;\">Selected: {{ active }}</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Start Date</p>\n        <input type=\"date\" v-model=\"start_date\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" />\n      </div>\n    </div>\n    <button @click=\"activate\" style=\"width:100%;padding:14px;background:#4caf50;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:500;cursor:pointer;\">\n      Set Active + Write Targets to Opta\n    </button>\n  </div>\n\n</div>\n\n<script>\nexport default {\n  data() {\n    return {\n      active: null,\n      start_date: new Date().toISOString().split('T')[0]\n    }\n  },\n  methods: {\n    activate() {\n      this.$socket.emit('msg-input:' + this.$ctxId, {\n        payload: { action: 'activate_crop', crop_name: this.active, start_date: this.start_date }\n      })\n    }\n  }\n}\n</script>\n</template>",

    {
        "id": "1a0bd6bd1e299bf3",
        "type": "ui-template",
        "z": "5b9088f11588525c",
        "group": "fb49d5e3789b0b98",
        "page": "",
        "ui": "",
        "name": "Settings",
        "order": 0,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n<div style=\"padding:16px;font-family:sans-serif;max-width:1024px;margin:0 auto;\">\n\n  <p style=\"font-size:11px;color:#888;margin:0 0 16px;text-transform:uppercase;letter-spacing:0.08em;\">Target Ranges</p>\n\n  <!-- pH -->\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <p style=\"font-size:13px;font-weight:500;margin:0 0 12px;\">pH</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Min</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"pH_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Max</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"pH_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n    </div>\n  </div>\n\n  <!-- EC -->\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <p style=\"font-size:13px;font-weight:500;margin:0 0 12px;\">EC (mS/cm)</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Min</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"ec_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Max</p>\n        <input type=\"number\" step=\"0.1\" v-model=\"ec_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n    </div>\n  </div>\n\n  <!-- Internal Temp -->\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <p style=\"font-size:13px;font-weight:500;margin:0 0 12px;\">Internal Temp (°F)</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Min</p>\n        <input type=\"number\" v-model=\"int_temp_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Max</p>\n        <input type=\"number\" v-model=\"int_temp_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n    </div>\n  </div>\n\n  <!-- Internal RH -->\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <p style=\"font-size:13px;font-weight:500;margin:0 0 12px;\">Internal RH (%)</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Min</p>\n        <input type=\"number\" v-model=\"rh_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Max</p>\n        <input type=\"number\" v-model=\"rh_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n    </div>\n  </div>\n\n  <!-- Crop Settings -->\n  <p style=\"font-size:11px;color:#888;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.08em;\">Crop Settings</p>\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <div style=\"margin-bottom:12px;\">\n      <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Crop Name</p>\n      <input type=\"text\" v-model=\"crop_name\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n    </div>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Start Date</p>\n        <input type=\"date\" v-model=\"start_date\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Days to Harvest</p>\n        <input type=\"number\" v-model=\"days_to_harvest\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;\" />\n      </div>\n    </div>\n  </div>\n\n  <!-- Save Button -->\n  <button @click=\"saveSettings\" style=\"width:100%;padding:14px;background:#4caf50;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:500;cursor:pointer;\">\n    Save Settings\n  </button>\n\n</div>\n\n<script>\nexport default {\n  data() {\n    return {\n      pH_min: 5.5,\n      pH_max: 6.5,\n      ec_min: 1.2,\n      ec_max: 2.4,\n      int_temp_min: 65,\n      int_temp_max: 80,\n      rh_min: 50,\n      rh_max: 70,\n      crop_name: 'Lettuce — Butterhead',\n      start_date: '',\n      days_to_harvest: 42\n    }\n  },\n  methods: {\n    saveSettings() {\n      this.$socket.emit('msg-input:settings', {\n        payload: {\n          pH_min: this.pH_min,\n          pH_max: this.pH_max,\n          ec_min: this.ec_min,\n          ec_max: this.ec_max,\n          int_temp_min: this.int_temp_min,\n          int_temp_max: this.int_temp_max,\n          rh_min: this.rh_min,\n          rh_max: this.rh_max,\n          crop_name: this.crop_name,\n          start_date: this.start_date,\n          days_to_harvest: this.days_to_harvest\n        }\n      })\n    }\n  }\n}\n</script>\n</template>",

    {
        "id": "cd94253ac9728d44",
        "type": "ui-template",
        "z": "190cd4b9f45ba92d",
        "group": "36b02f21cc66f12c",
        "page": "",
        "ui": "",
        "name": "Crop Profiles",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n<div style=\"padding:16px;font-family:sans-serif;\">\n\n  <p style=\"font-size:11px;color:#888;margin:0 0 12px;text-transform:uppercase;letter-spacing:0.08em;\">Crop Profiles</p>\n\n  <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;\">\n    <div v-for=\"crop in (msg.payload.crops || [])\" :key=\"crop.name\"\n      @click=\"selectCrop(crop)\"\n      :style=\"'background:' + (active && active.name === crop.name ? '#e8f5e9' : '#fff') + ';border:' + (active && active.name === crop.name ? '2px solid #4caf50' : '0.5px solid #e0e0e0') + ';border-radius:12px;padding:14px;cursor:pointer;'\">\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n        <div :style=\"'width:32px;height:32px;border-radius:8px;background:' + crop.color + ';'\"></div>\n        <div>\n          <p style=\"font-size:14px;font-weight:500;margin:0;\">{{ crop.name }}</p>\n          <p style=\"font-size:11px;color:#888;margin:0;\">{{ crop.days }} days to harvest</p>\n        </div>\n        <div v-if=\"active && active.name === crop.name\" style=\"margin-left:auto;background:#4caf50;color:#fff;font-size:10px;padding:2px 8px;border-radius:6px;\">Active</div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;\">\n        <p style=\"font-size:11px;color:#888;margin:0;\">pH: {{ crop.ph_min }}–{{ crop.ph_max }}</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">EC: {{ crop.ec_min }}–{{ crop.ec_max }} mS</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">Temp: {{ crop.temp_min }}–{{ crop.temp_max }}°F</p>\n        <p style=\"font-size:11px;color:#888;margin:0;\">RH: {{ crop.rh_min }}–{{ crop.rh_max }}%</p>\n      </div>\n    </div>\n  </div>\n\n  <div v-if=\"active && active.name\" style=\"background:#f5f5f5;border-radius:12px;padding:16px;margin-bottom:12px;\">\n    <p style=\"font-size:13px;font-weight:500;margin:0 0 12px;\">Active: {{ active.name }}</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;\">\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Start Date</p>\n        <input type=\"date\" v-model=\"start_date\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" />\n      </div>\n      <div>\n        <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Days to Harvest</p>\n        <input type=\"number\" v-model=\"active.days\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" />\n      </div>\n    </div>\n    <button @click=\"activate\" style=\"width:100%;padding:14px;background:#4caf50;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:500;cursor:pointer;\">\n      Set Active + Write Targets to Opta\n    </button>\n  </div>\n\n  <div style=\"background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px;\">\n    <p style=\"font-size:13px;font-weight:500;margin:0 0 12px;\">Custom Profile</p>\n    <div style=\"margin-bottom:10px;\">\n      <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Crop Name</p>\n      <input type=\"text\" v-model=\"custom.name\" placeholder=\"e.g. Cherry Tomato\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" />\n    </div>\n    <div style=\"display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:10px;\">\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">pH Min</p><input type=\"number\" step=\"0.1\" v-model=\"custom.ph_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">pH Max</p><input type=\"number\" step=\"0.1\" v-model=\"custom.ph_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">EC Min</p><input type=\"number\" step=\"0.1\" v-model=\"custom.ec_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">EC Max</p><input type=\"number\" step=\"0.1\" v-model=\"custom.ec_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Temp Min °F</p><input type=\"number\" v-model=\"custom.temp_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Temp Max °F</p><input type=\"number\" v-model=\"custom.temp_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">RH Min %</p><input type=\"number\" v-model=\"custom.rh_min\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n      <div><p style=\"font-size:11px;color:#888;margin:0 0 4px;\">RH Max %</p><input type=\"number\" v-model=\"custom.rh_max\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" /></div>\n    </div>\n    <div style=\"margin-bottom:10px;\">\n      <p style=\"font-size:11px;color:#888;margin:0 0 4px;\">Days to Harvest</p>\n      <input type=\"number\" v-model=\"custom.days\" style=\"width:100%;padding:8px;border:0.5px solid #e0e0e0;border-radius:8px;font-size:14px;box-sizing:border-box;\" />\n    </div>\n    <button @click=\"addCustom\" style=\"width:100%;padding:12px;background:#1e88e5;color:#fff;border:none;border-radius:12px;font-size:14px;font-weight:500;cursor:pointer;\">\n      Add Custom Profile\n    </button>\n  </div>\n\n</div>\n\n<script>\nexport default {\n  data() {\n    return {\n      start_date: new Date().toISOString().split('T')[0],\n      active: null,\n      custom: { name: '', days: 42, ph_min: 5.5, ph_max: 6.5, ec_min: 1.2, ec_max: 2.4, temp_min: 65, temp_max: 80, rh_min: 50, rh_max: 70 }\n    }\n  },\n  methods: {\n    selectCrop(crop) {\n      this.active = { ...crop }\n    },\n    activate() {\n      if (!this.active) return\n      const start = new Date(this.start_date)\n      const today = new Date()\n      const days_growth = Math.floor((today - start) / (1000 * 60 * 60 * 24))\n      const progress = Math.min(100, Math.round((days_growth / this.active.days) * 100))\n      this.$socket.emit('msg-input:' + this.$ctxId, {\n        payload: {\n          action: 'activate_crop',\n          crop_name: this.active.name,\n          start_date: this.start_date,\n          days_growth,\n          days_to_harvest: this.active.days,\n          progress,\n          ph_min: this.active.ph_min,\n          ph_max: this.active.ph_max,\n          ec_min: this.active.ec_min,\n          ec_max: this.active.ec_max,\n          temp_min: this.active.temp_min,\n          temp_max: this.active.temp_max,\n          rh_min: this.active.rh_min,\n          rh_max: this.active.rh_max\n        }\n      })\n    },\n    addCustom() {\n      if (!this.custom.name) return\n      this.custom = { name: '', days: 42, ph_min: 5.5, ph_max: 6.5, ec_min: 1.2, ec_max: 2.4, temp_min: 65, temp_max: 80, rh_min: 50, rh_max: 70 }\n    }\n  }\n}\n</script>\n</template>",
